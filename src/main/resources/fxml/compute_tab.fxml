<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.ui.controller.ComputeTabController"
            styleClass="tab-content">

    <!-- ═══════════════════════════════════════════════════════════
         CENTER — головна область з прокруткою
         ═══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge">
            <VBox spacing="14">
                <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>

                <!-- ── Блок 1: Параметри ─────────────────────────── -->
                <TitledPane text="Параметри обчислення" collapsible="false"
                            styleClass="section-pane">
                    <GridPane hgap="16" vgap="10">
                        <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>

                        <!-- Колонки -->
                        <columnConstraints>
                            <ColumnConstraints minWidth="130" maxWidth="160"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Рядок 0: Програма -->
                        <Label text="Програма:" styleClass="param-label"
                               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <RadioButton fx:id="radioPRG1" text="ПРГ1  MA = MB × (MC × MD)"
                                         styleClass="prg-radio" selected="true"/>
                            <RadioButton fx:id="radioPRG2" text="ПРГ2  MA = MB×MC + MD×ME"
                                         styleClass="prg-radio"/>
                            <RadioButton fx:id="radioPRG3" text="ПРГ3  MA = max(MR) × (MB × MC)"
                                         styleClass="prg-radio"/>
                        </HBox>

                        <!-- Рядок 1: Розмір N -->
                        <Label text="Розмір матриць N:" styleClass="param-label"
                               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <Spinner fx:id="spinnerN" prefWidth="120"
                                     editable="true" styleClass="param-spinner"/>
                            <Label text="(N×N елементів)" styleClass="hint-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Потоків P:" styleClass="param-label"/>
                            <Spinner fx:id="spinnerP" prefWidth="90"
                                     editable="true" styleClass="param-spinner"/>
                            <Label fx:id="labelCpuHint" text="" styleClass="hint-label"/>
                        </HBox>

                        <!-- Рядок 2: Кнопка запуску -->
                        <Label GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <HBox spacing="12" alignment="CENTER_LEFT"
                              GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <Button fx:id="btnRun" text="▶  Запустити"
                                    styleClass="button,run-button"
                                    onAction="#onRun" prefWidth="150"/>
                            <Button fx:id="btnCancel" text="✕  Скасувати"
                                    styleClass="button,secondary"
                                    onAction="#onCancel"
                                    disable="true" prefWidth="130"/>
                            <ProgressIndicator fx:id="progressIndicator"
                                               prefWidth="22" prefHeight="22"
                                               visible="false"/>
                            <Label fx:id="labelRunStatus" text=""
                                   styleClass="run-status-label"/>
                        </HBox>

                    </GridPane>
                </TitledPane>

                <!-- ── Блок 2: Результат виконання ──────────────── -->
                <TitledPane fx:id="paneResult" text="Результат виконання"
                            collapsible="false" styleClass="section-pane">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>

                        <!-- Рядок метрик -->
                        <HBox spacing="24" alignment="CENTER_LEFT"
                              styleClass="metrics-bar">
                            <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>

                            <VBox spacing="2" alignment="CENTER">
                                <Label text="Час виконання" styleClass="metric-caption"/>
                                <Label fx:id="labelTime" text="—" styleClass="metric-value"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox spacing="2" alignment="CENTER">
                                <Label text="Програма" styleClass="metric-caption"/>
                                <Label fx:id="labelPrg" text="—" styleClass="metric-value"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox spacing="2" alignment="CENTER">
                                <Label text="Розмір N" styleClass="metric-caption"/>
                                <Label fx:id="labelN" text="—" styleClass="metric-value"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox spacing="2" alignment="CENTER">
                                <Label text="Потоків P" styleClass="metric-caption"/>
                                <Label fx:id="labelP" text="—" styleClass="metric-value"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox spacing="2" alignment="CENTER">
                                <Label text="Розмір MA (МБ)" styleClass="metric-caption"/>
                                <Label fx:id="labelMemory" text="—" styleClass="metric-value"/>
                            </VBox>
                        </HBox>

                        <!-- Таблиця результатів (заповнюється у Фазі 6б) -->
                        <TableView fx:id="tableResult"
                                   prefHeight="320"
                                   placeholder="$labelTablePlaceholder"
                                   styleClass="result-table">
                            <columns>
                                <TableColumn fx:id="colRow"  text="Рядок"    prefWidth="80"/>
                                <TableColumn fx:id="colCol"  text="Стовпець" prefWidth="90"/>
                                <TableColumn fx:id="colVal"  text="MA[i][j]" prefWidth="160"/>
                            </columns>
                        </TableView>
                        <Label fx:id="labelTablePlaceholder"
                               text="Натисніть «Запустити» для обчислення"
                               styleClass="placeholder-label"/>

                    </VBox>
                </TitledPane>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════
         BOTTOM — панель дій
         ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox styleClass="action-bar" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>

            <Button fx:id="btnCopy" text="📋  Копіювати"
                    styleClass="button,secondary"
                    onAction="#onCopy" disable="true"/>
            <Button fx:id="btnSaveCsv" text="💾  Зберегти CSV"
                    styleClass="button,secondary"
                    onAction="#onSaveCsv" disable="true"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelActionStatus" text="" styleClass="hint-label"/>
        </HBox>
    </bottom>

</BorderPane>
